FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/maven:3.9.9-eclipse-temurin-21-noble AS build
WORKDIR /app

# Copy pom.xml files first for dependency caching
COPY console/backend/pom.xml /app/console/backend/pom.xml
COPY console/backend/hub/pom.xml /app/console/backend/hub/pom.xml
COPY console/backend/commons/pom.xml /app/console/backend/commons/pom.xml
COPY console/backend/toolkit/pom.xml /app/console/backend/toolkit/pom.xml

# Download dependencies (cached unless pom.xml changes)
WORKDIR /app/console/backend
RUN mvn dependency:go-offline -B

# Copy source code and build
COPY console/backend /app/console/backend
RUN mvn clean package -DskipTests

# Runtime stage
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/eclipse-temurin:21-jre
WORKDIR /app

# Set timezone
RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone

# Copy the built jar
COPY --from=build /app/console/backend/hub/target/hub-server.jar /app/hub-server.jar

# Create logs directory
RUN mkdir -p /app/logs

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost:8080/actuator/health || exit 1

# Entrypoint
ENTRYPOINT ["java", \
    "-XX:+UseContainerSupport", \
    "-XX:MaxRAMPercentage=75.0", \
    "-Djava.security.egd=file:/dev/./urandom", \
    "-Duser.timezone=Asia/Shanghai", \
    "-jar", \
    "/app/hub-server.jar"]
